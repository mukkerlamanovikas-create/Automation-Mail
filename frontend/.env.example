# For local dev: leave VITE_API_URL empty (Vite proxy handles /api/* → localhost:3001)
# For production: leave empty if frontend & backend share the same Vercel domain
VITE_API_URL=

# Worker secret — same value as WORKER_SECRET in backend .env
# Used by the "Process Now" button to call /api/worker/process?secret=...
VITE_WORKER_SECRET=your_worker_secret_here
