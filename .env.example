# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_64_char_hex_string_here

# ── Gmail App Password Encryption ─────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_string_here

# ── Worker ────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
WORKER_SECRET=your_worker_secret_here

# ── System Email (for password reset links) ───────────────────────────────────
SYSTEM_EMAIL_FROM=youremail@gmail.com
SYSTEM_EMAIL_PASSWORD=your_gmail_app_password_here

# ── App URL (for reset password links in emails) ──────────────────────────────
APP_URL=https://your-app.vercel.app

# ── Local Dev ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
